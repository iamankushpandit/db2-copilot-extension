# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── GitHub App Credentials (required) ─────────────────────────────────────────
CLIENT_ID=your_github_app_client_id
CLIENT_SECRET=your_github_app_client_secret

# Public URL of this agent (e.g. from ngrok, Cloudflare Tunnel, or your server)
FQDN=https://your-ngrok-url.ngrok.app

# ── Database Configuration ─────────────────────────────────────────────────────
# Supported types: db2, postgres  (default: db2 for backward compatibility)
DB_TYPE=postgres

# ── PostgreSQL Connection (required if DB_TYPE=postgres) ──────────────────────
# URL format:
POSTGRES_CONN_STRING=postgres://postgres:password@localhost:5432/sample?sslmode=disable
# Keyword=value format (alternative):
# POSTGRES_CONN_STRING=host=localhost port=5432 user=postgres password=secret dbname=sample sslmode=disable

# ── IBM DB2 Connection (required if DB_TYPE=db2) ──────────────────────────────
# Note: DB2 support requires building with -tags db2 and the IBM DB2 CLI installed.
# See README.md for full DB2 setup instructions.
DB2_CONN_STRING=HOSTNAME=localhost;PORT=50000;DATABASE=sample;UID=db2inst1;PWD=password;PROTOCOL=TCPIP
