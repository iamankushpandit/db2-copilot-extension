# ── Server ─────────────────────────────────────────────────────────────────────
# Port the agent HTTP server listens on (default: 8080)
PORT=8080

# ── GitHub App ─────────────────────────────────────────────────────────────────
# Client ID from your GitHub App (Settings > Developer Settings > GitHub Apps)
CLIENT_ID=your_github_app_client_id

# Client Secret generated for your GitHub App
CLIENT_SECRET=your_github_app_client_secret

# Public URL where this agent is reachable (e.g., your ngrok forwarding address)
# Must NOT have a trailing slash
FQDN=https://your-ngrok-url.ngrok.app

# ── Config Directory ───────────────────────────────────────────────────────────
# Directory containing JSON config files (default: "config")
# Files auto-created with defaults on first run:
#   access_config.json  — schema access control
#   query_safety.json   — row limits, cost thresholds, rate limits
#   llm_config.json     — LLM provider selection (Copilot / Ollama)
#   glossary.json       — business term definitions
#   admin_config.json   — admin UI settings and database type
CONFIG_DIR=config

# ── Database ───────────────────────────────────────────────────────────────────
# Set database.type in config/admin_config.json to "postgres" or "db2".

# PostgreSQL connection string (used when database.type = "postgres")
DATABASE_URL=postgres://readonly_user:password@localhost:5432/mydb?sslmode=require

# IBM DB2 connection string in ODBC format (used when database.type = "db2")
# HOSTNAME  — DB2 server hostname or IP address
# PORT      — DB2 server port (default 50000)
# DATABASE  — Database name (e.g., SAMPLE)
# UID       — DB2 username (use a read-only account for safety)
# PWD       — DB2 password
# PROTOCOL  — Always TCPIP for network connections
DB2_CONN_STRING=HOSTNAME=localhost;PORT=50000;DATABASE=sample;UID=db2inst1;PWD=password;PROTOCOL=TCPIP
