# ── Server ─────────────────────────────────────────────────────────────────────
# Port the agent HTTP server listens on (default: 8080)
PORT=8080

# ── GitHub App ─────────────────────────────────────────────────────────────────
# Client ID from your GitHub App (Settings > Developer Settings > GitHub Apps)
CLIENT_ID=your_github_app_client_id

# Client Secret generated for your GitHub App
CLIENT_SECRET=your_github_app_client_secret

# Public URL where this agent is reachable (e.g., your ngrok forwarding address)
# Must NOT have a trailing slash
FQDN=https://your-ngrok-url.ngrok.app

# ── IBM DB2 ─────────────────────────────────────────────────────────────────────
# DB2 connection string in ODBC format
# HOSTNAME  — DB2 server hostname or IP address
# PORT      — DB2 server port (default 50000)
# DATABASE  — Database name (e.g., SAMPLE)
# UID       — DB2 username (use a read-only account for safety)
# PWD       — DB2 password
# PROTOCOL  — Always TCPIP for network connections
DB2_CONN_STRING=HOSTNAME=localhost;PORT=50000;DATABASE=sample;UID=db2inst1;PWD=password;PROTOCOL=TCPIP
